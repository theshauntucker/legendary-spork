{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/traffic-summary",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/cleanup-frames",
      "schedule": "0 * * * *"
    }
  ]
}
